# PostHog (website analytics). Cookieless, no banner needed.
# See app/lib/analytics.ts for the strict-mode config.
# Project key from posthog.com → Project → Settings → API key.
VITE_POSTHOG_KEY=
# Optional. Defaults to https://us.i.posthog.com.
# Set to https://eu.i.posthog.com if your project is in the EU region.
VITE_POSTHOG_HOST=

# Polar checkout links (https://polar.sh → Products → Checkout Links).
# Each value is a full https URL.
#
# Production values live in .env.production (committed, loaded by
# `vite build`). Set values here only if you want them used for local
# `vite dev`. SANDBOX is safe to commit (it's a public sandbox URL);
# LIVE in .env.production is also safe — Polar checkout links are
# meant to be public.
VITE_POLAR_LIVE_URL=
VITE_POLAR_SANDBOX_URL=
