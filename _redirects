# Hide source/tooling from public URLs. The trailing `!` forces the
# redirect even when a matching file exists on disk (Cloudflare's
# default behavior is "static file wins over redirect rule").
/src/*               /  301!
/src                 /  301!
/build.mjs           /  301!
/package.json        /  301!
/package-lock.json   /  301!
/node_modules/*      /  301!
/.githooks/*         /  301!
/.gitignore          /  301!
/.assetsignore       /  301!
